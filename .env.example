# SQL Server Azure
DB_SERVER=srv-dwh-grupopoint.database.windows.net
DB_DATABASE=dwh-grupopoint-prod
DB_USER=Admin_point
DB_PASSWORD=your_db_password
DB_PORT=1433

# JWT
JWT_SECRET=your_jwt_secret_change_this
JWT_EXPIRES_IN=8h

# Server
PORT=3001
NODE_ENV=development

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Microsoft 365 / Graph API (for SAP alert emails)
# Register app in Azure AD: https://portal.azure.com > App registrations
# Required API permissions: Mail.Read (Application type), for mailbox alertasSapPA@pointamericas.com
MS_TENANT_ID=your_azure_ad_tenant_id
MS_CLIENT_ID=your_app_registration_client_id
MS_CLIENT_SECRET=your_app_registration_client_secret
MS_ALERT_EMAIL=alertasSapPA@pointamericas.com
